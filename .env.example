# ── 번역 엔진 선택 ─────────────────────────────────────────────
# claude (기본값) 또는 gemini
TRANSLATOR_BACKEND=gemini

# ── Claude (Anthropic) ─────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 모델 변경 시 아래 주석 해제 (기본값: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Gemini (Google) ────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 모델 변경 시 아래 주석 해제 (기본값: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── 레이아웃 분석 모델 (선택사항) ─────────────────────────────
# 표 위치 추정에 더 정확한 모델을 사용하려면 아래 주석 해제
# 미설정 시 기본 번역 모델(GEMINI_MODEL / CLAUDE_MODEL)을 그대로 사용
# Gemini 예시 (번역보다 강력한 Vision 모델):
# LAYOUT_MODEL=gemini-2.0-flash
# Claude 예시:
# LAYOUT_MODEL=claude-sonnet-4-6
